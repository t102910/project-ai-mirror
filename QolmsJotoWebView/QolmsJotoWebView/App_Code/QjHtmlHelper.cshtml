@helper ToHourDropDownList(string id, string name, string selected, string css = "form-control hour")
{
    string value = string.Empty;

    <select id="@id" name="@name" class="@css">
        @for (int a = 0; a <= 11; a++)
        {
            value = a.ToString();

            if ((selected ?? string.Empty).CompareTo(value) == 0)
            {
                <option value="@value" selected="selected">@String.Format("{0}", value)</option>
            }
            else
            {
                <option value="@value">@String.Format("{0}", value)</option>
            }
        }
    </select>
    <span class="input-group-addon hour2">時</span>
}

@helper ToMinuteDropDownList(string id, string name, string selected, string css = "form-control minute")
{
    var hash = new HashSet<string>();

    for (int a = 0; a <= 59; a++)
    {
        hash.Add(a.ToString());
    }

    <select id="@id" name="@name" class="@css">
        @foreach (string s in hash)
        {
            if (s.CompareTo(selected) == 0)
            {
                <option value="@s" selected="selected">@String.Format("{0}", s)</option>
            }
            else
            {
                <option value="@s">@String.Format("{0}", s)</option>
            }
        }
    </select>
    <span class="input-group-addon minute2">分</span>
}

