@helper ToValidationMessageArea(IEnumerable<string> keys, object errorMessage, string css = "block alert alert-danger thin mt10", bool useP = false)
{
    var messages = new List<string>();

    if (keys != null && keys.Count() > 0 && errorMessage != null && (errorMessage is Dictionary<string, string>))
    {
        var dic = (Dictionary<string, string>)errorMessage;

        foreach (string key in keys)
        {
            if (dic.ContainsKey(key) && !string.IsNullOrWhiteSpace(dic[key]))
            {
                messages.Add(dic[key]);
            }
        }
    }

    if (messages.Count > 0)
    {
        if (!useP)
        {
            <span class="@css">@QjHtmlHelper.CrLfToBreakTag(string.Join(Environment.NewLine, messages))</span>
        }
        else
        {
            <p class="@css">@QjHtmlHelper.CrLfToBreakTag(string.Join(Environment.NewLine, messages))</p>
        }
    }
    else
    {
        if (!useP)
        {
            <span class="@css hide"></span>
        }
        else
        {
            <p class="@css hide"></p>
        }
    }
}

