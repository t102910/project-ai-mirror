@helper CrLfToSpanTag(string s)
{
    List<string> items = (s ?? string.Empty)
        .Replace("\r\n", "\n")
        .Replace("\r", "\n")
        .Split('\n')
        .ToList();

    if (items != null)
    {
        if (items.Count > 0)
        {
            foreach (string item in items)
            {
                <span>@item</span>
            }
        }
        else
        {
            <span>@s</span>
        }
    }
}

@helper CrLfToBreakTag(string s)
{
    List<string> items = (s ?? string.Empty)
        .Replace("\r\n", "\n")
        .Replace("\r", "\n")
        .Split('\n')
        .ToList();

    if (items != null)
    {
        if (items.Count > 0)
        {
            foreach (string item in items)
            {
                @item
                <br />
            }
        }
        else
        {
            @s
        }
    }
}

