@using System
@using MGF.QOLMS.QolmsJotoWebView
@model IntegrationHospitalConnectionRequestViewModel

@{
    ViewData["Title"] = "病院連携申請";
    Layout = "~/Views/Shared/_IntegrationLayout.cshtml";
}

<body id="hospital-connection-request" class="lower">
    @Html.AntiForgeryToken()

    <main id="main-cont" class="clearfix" role="main">
        <section class="home-btn-wrap">
            <a href="../Portal/Home" class="home-btn"><i class="la la-angle-left"></i></a>
        </section>

        <section class="contents-area">
            <h2 class="title">病院連携申請</h2>
            <hr>

            <section class="section default">
                @Model.HospitalName と連携します。<br />
                病院コードと診察券番号を入力し、連携内容を確認してください。
            </section>

            <div class="form wizard-form mb30">
                <label for="hospital-code" class="t-row line">
                    <span class="label-txt"><span class="ico required">必須</span> 病院コード</span>
                    <input type="text" id="hospital-code" class="form-control mb10" placeholder="病院コード" value="@Model.HospitalCode" maxlength="25" autocomplete="off" />
                </label>

                <label for="patient-no" class="t-row line">
                    <span class="label-txt"><span class="ico required">必須</span> 診察券番号</span>
                    <input type="text" id="patient-no" class="form-control mb10" placeholder="診察券番号" value="@Model.PatientNo" maxlength="25" autocomplete="off" />
                </label>

                <div class="t-row line">
                    <label class="label-txt"><span class="ico required">必須</span> お名前</label>
                    <input type="text" id="family-name" class="form-control mb10" placeholder="姓" value="@Model.FamilyName" maxlength="25" autocomplete="off" />
                    <input type="text" id="given-name" class="form-control" placeholder="名" value="@Model.GivenName" maxlength="25" autocomplete="off" />
                </div>

                <div class="t-row line">
                    <label class="label-txt"><span class="ico required">必須</span> 生年月日</label>
                    <p id="birthday" style="font-size:16px; padding:10px 12px;">@Model.BirthDateLabel</p>
                </div>

                <div class="t-row">
                    <label class="label-txt"><span class="ico required">必須</span> 同意確認</label>
                    <div class="wizard-form inline-block link-ico tanita" id="connection-data">
                        <input id="ConsentFlag" type="checkbox" value="true" @(Model.ConsentFlag ? "checked=\"checked\"" : string.Empty) />
                        <label for="ConsentFlag">検査・健診情報を取得することに同意する</label>
                    </div>
                </div>


                <p class="submit-area mb30">
                    <a id="request" href="javascript:void(0);" class="btn btn-submit" data-hospitalname="@Model.HospitalName">確 認</a>
                </p>
            </div>
        </section>

        <div class="modal fade" id="confirm-modal" tabindex="-1" data-backdrop="static" data-keyboard="false">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close"><span>×</span></button>
                        <h4 class="modal-title">確認</h4>
                    </div>
                    <div class="modal-body">病院連携の完了画面へ移動します。よろしいですか？</div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-close no-ico mb0">閉じる</button>
                        <button type="button" class="btn btn-delete">進 む</button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    @Html.Action("IntegrationFooterPartialView", "Integration")

    <script src="~/dist/js/jquery-3.7.1.min.js"></script>
    <script src="~/dist/js/bootstrap.bundle.js"></script>
    <script src="~/dist/js/slick.min.js"></script>
    <script src="~/dist/js/spc.lib.min.js"></script>
    <script src="~/dist/js/spc.util.min.js"></script>
    <script src="~/dist/js/page-script/mgf.js"></script>
    <script src="~/dist/js/page-script/mgf.portal.js"></script>
    <script src="~/dist/js/page-script/mgf.integration.hospitalconnectionrequest.js"></script>
</body>
