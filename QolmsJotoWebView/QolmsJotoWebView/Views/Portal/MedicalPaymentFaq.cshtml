@{
    ViewData["Title"] = "よくあるご質問";
    Layout = "~/Views/Shared/_PortalLayout.cshtml";
}

<body id="pay-later" class="lower">
    @Html.AntiForgeryToken()

    <main id="main-cont" class="clearfix" role="main">
        <section class="home-btn-wrap" data-pageno="8">
            <a href="../Portal/MedicalPayment" class="home-btn"><i class="la la-angle-left"></i></a>
        </section>

        <section class="contents-area">
            <h2 class="title">よくあるご質問</h2>
            <hr>

            <div class="accordion faq-accordion" id="faqAccordion">

                <div class="accordion-item">
                    <h2 class="accordion-header" id="faq-h1">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-c1" aria-expanded="false" aria-controls="faq-c1">
                            Q: あと払いを利用したいのですが、どうすればよいですか？
                        </button>
                    </h2>
                    <div id="faq-c1" class="accordion-collapse collapse" aria-labelledby="faq-h1" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            まず会員登録が必要です。マイページより新規登録をお申し込みください。
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="faq-h2">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-c2" aria-expanded="false" aria-controls="faq-c2">
                            Q: 会員と支払者は同じでなければならないの？
                        </button>
                    </h2>
                    <div id="faq-c2" class="accordion-collapse collapse" aria-labelledby="faq-h2" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            いいえ、家族会員登録をすることで、家族の医療費もまとめてお支払いいただけます。
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="faq-h3">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-c3" aria-expanded="false" aria-controls="faq-c3">
                            Q: あと払いの利用対象は？
                        </button>
                    </h2>
                    <div id="faq-c3" class="accordion-collapse collapse" aria-labelledby="faq-h3" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            本サービスに対応している医療機関でご利用いただけます。
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="faq-h4">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-c4" aria-expanded="false" aria-controls="faq-c4">
                            Q: あと払いの利用方法は？
                        </button>
                    </h2>
                    <div id="faq-c4" class="accordion-collapse collapse" aria-labelledby="faq-h4" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            会員登録後、対象の医療機関の受付で「あと払い」をご利用の旨をお伝えください。
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="faq-h5">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-c5" aria-expanded="false" aria-controls="faq-c5">
                            Q: 複数の医療機関であと払いを使うことはできますか？
                        </button>
                    </h2>
                    <div id="faq-c5" class="accordion-collapse collapse" aria-labelledby="faq-h5" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            はい、対応している複数の医療機関でご利用いただけます。
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="faq-h6">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-c6" aria-expanded="false" aria-controls="faq-c6">
                            Q: 利用料金はかかりますか？
                        </button>
                    </h2>
                    <div id="faq-c6" class="accordion-collapse collapse" aria-labelledby="faq-h6" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            登録料・年会費は無料です。詳しくはお客様窓口へお問い合わせください。
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="faq-h7">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-c7" aria-expanded="false" aria-controls="faq-c7">
                            Q: あと払いに登録したら、毎回利用しなければならないの？
                        </button>
                    </h2>
                    <div id="faq-c7" class="accordion-collapse collapse" aria-labelledby="faq-h7" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            いいえ、毎回の利用は任意です。通常の会計も引き続きご利用いただけます。
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="faq-h8">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-c8" aria-expanded="false" aria-controls="faq-c8">
                            Q: あと払いを利用した場合の支払い日はいつですか？
                        </button>
                    </h2>
                    <div id="faq-c8" class="accordion-collapse collapse" aria-labelledby="faq-h8" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            毎月締め日以降に請求書をお送りします。詳しくはマイページでご確認ください。
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="faq-h9">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-c9" aria-expanded="false" aria-controls="faq-c9">
                            Q: 金額の確認をしたい場合はどうすればよいですか？
                        </button>
                    </h2>
                    <div id="faq-c9" class="accordion-collapse collapse" aria-labelledby="faq-h9" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            マイページにてご利用明細をご確認いただけます。
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="faq-h10">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-c10" aria-expanded="false" aria-controls="faq-c10">
                            Q: 領収書・明細書はもらえますか？
                        </button>
                    </h2>
                    <div id="faq-c10" class="accordion-collapse collapse" aria-labelledby="faq-h10" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            マイページより明細をご確認いただけます。領収書については医療機関にお問い合わせください。
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="faq-h11">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-c11" aria-expanded="false" aria-controls="faq-c11">
                            Q: 会員情報を変更したい場合はどうすればよいですか？
                        </button>
                    </h2>
                    <div id="faq-c11" class="accordion-collapse collapse" aria-labelledby="faq-h11" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            マイページの「会員情報変更」よりお手続きいただけます。
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="faq-h12">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-c12" aria-expanded="false" aria-controls="faq-c12">
                            Q: 退会したい場合はどうすればよいですか？
                        </button>
                    </h2>
                    <div id="faq-c12" class="accordion-collapse collapse" aria-labelledby="faq-h12" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            マイページの「退会手続き」よりお申し込みいただけます。
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="faq-h13">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-c13" aria-expanded="false" aria-controls="faq-c13">
                            Q: マイページのID・パスワードを忘れた場合はどうすればよいですか？
                        </button>
                    </h2>
                    <div id="faq-c13" class="accordion-collapse collapse" aria-labelledby="faq-h13" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            マイページのログイン画面の「ID・パスワードを忘れた方はこちら」よりお手続きください。
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="faq-h14">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-c14" aria-expanded="false" aria-controls="faq-c14">
                            Q: JOTOホームドクターを途中退会した場合、利用料金はどうなりますか？
                        </button>
                    </h2>
                    <div id="faq-c14" class="accordion-collapse collapse" aria-labelledby="faq-h14" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            退会月までのご利用分はお支払いいただく必要があります。詳しくはお客様窓口へお問い合わせください。
                        </div>
                    </div>
                </div>

            </div>

            <section class="section default mt20">
                <h3 class="title">医療費あと払い お客様窓口</h3>
                <p>
                    お客さま窓口は「金額確認」及び「あと払い」のご利用方法についての窓口です。<br>
                    診療内容についてはご利用の医療機関にお問い合わせください。
                </p>
            </section>

            <a href="tel:0120-515-851" class="tel-link">0120-515-851</a>

            <section class="section default">
                受付時間 9:00〜17:00（土・日・祝祭日・年末年始除く）<br>
                株式会社エムイーエックステクノロジーズ
            </section>
        </section>
    </main>

    @Html.Action("PortalFooterPartialView", "Portal")

    <script src="~/dist/js/jquery-3.7.1.min.js"></script>
    <script src="~/dist/js/bootstrap.bundle.js"></script>
    <script src="~/dist/js/slick.min.js"></script>
    <script src="~/dist/js/spc.lib.min.js"></script>
    <script src="~/dist/js/spc.util.min.js"></script>
    <script src="~/dist/js/page-script/mgf.js"></script>
    <script src="~/dist/js/page-script/mgf.portal.js"></script>
</body>